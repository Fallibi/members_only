<div class="flex justify-between items-center mb-6">
  <h1 class="text-3xl font-bold">Secret Posts</h1>
  <div class="flex items-center space-x-4">
    <% if user_signed_in? %>
      <span class="text-gray-800">Welcome, <%= current_user.name %>!</span>
      <%= link_to "New Post", new_post_path, class: "bg-blue-500 text-white px-3 py-2 rounded-lg" %>
      <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "bg-red-500 text-white px-3 py-2 rounded-lg" %>
    <% else %>
      <%= link_to "Sign In", new_user_session_path, class: "text-blue-600 hover:underline" %>
      <%= link_to "Sign Up", new_user_registration_path, class: "text-blue-600 hover:underline" %>
    <% end %>
  </div>
</div>

<div id="posts">
  <%= render @posts %>
</div>
